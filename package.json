{
  "name": "file-explorer",
  "version": "1.0.0",
  "description": "Advanced file explorer — Cascade design",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "prepackage": "node scripts/generate-icon.mjs",
    "package": "electron-vite build && electron-builder --publish=never"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.cascade.fileexplorer",
    "productName": "Cascade",
    "publish": null,
    "icon": "resources/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**"
    ],
    "win": {
      "target": "zip",
      "icon": "resources/icon.png"
    },
    "mac": {
      "target": "zip",
      "category": "public.app-category.utilities",
      "icon": "resources/icon.png"
    },
    "linux": {
      "target": "tar.gz",
      "category": "Utility",
      "icon": "resources/icon.png"
    }
  }
}
